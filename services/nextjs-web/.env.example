# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-southeast-1
S3_BUCKET_NAME=recruitai-cvs

# VAPI
NEXT_PUBLIC_VAPI_ASSISTANT_ID=YOUR_VAPI_ASSISTANT_ID
NEXT_PUBLIC_VAPI_PUBLIC_KEY=YOUR_VAPI_PUBLIC_KEY
# Webhook: must match the assistant "Server URL" secret in Vapi (serverUrlSecret) or the X-Vapi-Secret credential.
# HMAC: Vapi signs the raw body with x-vapi-signature; also accepts plain x-vapi-secret when set.
# Required in production. Use the same value you configure in the Vapi dashboard.
# VAPI_WEBHOOK_SECRET=your-server-url-secret
# In Vapi: Assistant (or org) > Server > Server URL = https://your-domain.com/api/v1/webhooks/vapi
# In Vapi: enable server message "end-of-call-report" (see https://docs.vapi.ai/server-url/events )
# Candidates pass ?applicationId=<uuid> to the interview page so the call includes variableValues.applicationId for the webhook to resolve the application.

# Judge0 (code execution — self-hosted or cloud)
# No trailing slash. Example: EC2 Judge0 CE on port 2358
# Optional: JavaScript = 63 (Judge0 language IDs). Defaults to 63 if unset.
# JUDGE0_TEST_LANGUAGE_ID=63
# Optional: if your Judge0 instance requires auth
# JUDGE0_API_TOKEN=

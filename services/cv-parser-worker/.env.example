# Redis/BullMQ
REDIS_URL=redis://127.0.0.1:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_USERNAME=
# REDIS_PASSWORD=
# REDIS_TLS=false

# Supabase (server-side)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# AWS S3
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
S3_BUCKET_NAME=recruitai-cvs

# CV parser worker behavior
CV_PARSER_CONCURRENCY=2
CV_PARSER_VERSION=1
CV_PARSER_TIMEOUT_MS=30000
CV_PARSER_PROVIDER=gemini
CV_PARSER_FALLBACK_PROVIDER=grok
CV_PARSER_DISABLE_FALLBACK=false
CV_PARSER_MAX_TEXT_CHARS=20000

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# Grok/xAI
GROK_API_KEY=your-grok-api-key
# XAI_API_KEY=your-grok-api-key
GROK_MODEL=grok-2-latest
